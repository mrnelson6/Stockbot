# Alpaca API Credentials
# Get your keys from https://app.alpaca.markets/
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Use paper trading endpoint (set to "live" for real trading)
ALPACA_PAPER=true

# --- Random bot (scripts/random_portfolio.py) ---
# The random bot runs its OWN isolated portfolio. An Alpaca account IS its keys,
# so for true separation from the ML bot, create a SECOND Alpaca paper account
# and put its keys here. If these are unset, the random bot falls back to the
# ALPACA_* keys above and will share (and fight over) the ML bot's account.
RANDOM_ALPACA_API_KEY=your_second_account_api_key_here
RANDOM_ALPACA_SECRET_KEY=your_second_account_secret_key_here
RANDOM_ALPACA_PAPER=true

# Logging level (DEBUG, INFO, WARNING, ERROR)
STOCKBOT_LOG_LEVEL=INFO

# Data directory for parquet files
STOCKBOT_DATA_DIR=./data

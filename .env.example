# Copy this file to ".env" and fill in your real values. ".env" is gitignored.
# =============================================================================

# --- Shared Alpaca credentials (ML bot, and the random bot's fallback) -------
# Get your keys from https://app.alpaca.markets/
# Paper and live accounts have DIFFERENT keys — use the pair that matches the
# ALPACA_PAPER setting below.
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# true  = paper trading endpoint (fake money)
# false = LIVE trading endpoint (real money)  <-- requires LIVE account keys above
ALPACA_PAPER=true


# --- Random bot (scripts/random_portfolio.py) --------------------------------
# The random bot runs its OWN isolated portfolio. An Alpaca account IS its keys,
# so for true separation from the ML bot, create a SECOND Alpaca account and put
# its keys here. If these are unset, the random bot falls back to the ALPACA_*
# keys above and will share (and fight over) the ML bot's account.
RANDOM_ALPACA_API_KEY=your_second_account_api_key_here
RANDOM_ALPACA_SECRET_KEY=your_second_account_secret_key_here

# Paper vs live for the RANDOM bot specifically. This one var does two things:
#   1. Picks the paper or live trading endpoint (must match the keys above —
#      paper keys with true, live keys with false).
#   2. Selects the dashboard database, so the public site follows the account:
#        true  -> data/dashboard-paper.db
#        false -> data/dashboard-live.db
# To switch the random bot from paper to live: set this to false, swap in your
# LIVE RANDOM_ALPACA_* keys, and restart the bot + web services. The dashboard
# starts fresh on the live DB; the paper history is preserved in its own file.
RANDOM_ALPACA_PAPER=true


# --- General -----------------------------------------------------------------
# Logging level (DEBUG, INFO, WARNING, ERROR)
STOCKBOT_LOG_LEVEL=INFO

# Data directory (parquet caches AND the dashboard SQLite files live here).
STOCKBOT_DATA_DIR=./data

# Optional: hard-override the dashboard DB path. Leave unset to let it auto-
# select dashboard-{paper,live}.db from RANDOM_ALPACA_PAPER above (recommended).
# STOCKBOT_WEB_DB=./data/dashboard.db
